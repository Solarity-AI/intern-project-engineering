{
  "name": "urunapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "node -e \"if (!process.env.EXPO_PUBLIC_API_URL) { console.error('\\nError: EXPO_PUBLIC_API_URL is not set\\n'); process.exit(1); }\" && expo export --platform web",
    "postbuild": "node -e \"const fs = require('fs'); if (fs.existsSync('public')) { fs.cpSync('public', 'dist', { recursive: true }); }\"",
    "export": "expo export --platform web",
    "perf:multiselect": "node ./scripts/perf/multiselect-performance-check.js",
    "perf:multiselect:ci": "node ./scripts/perf/multiselect-performance-check.js --strict",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.node.config.js",
    "test:ui": "jest --config jest.ui.config.js"
  },
  "dependencies": {
    "@clerk/expo": "^3.0.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "expo": "~54.0.31",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-navigation-bar": "~5.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "@types/uuid": "^10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "expo-crypto": "~15.0.8",
    "scheduler": "0.27.0"
  }
}
